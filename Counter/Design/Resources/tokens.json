{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Counter design tokens — W3C DTCG tiered model. Swift source in Counter/Design/Tokens is canonical.",
  "color": {
    "base": {
      "white": { "$type": "color", "$value": "#ffffff" },
      "black": { "$type": "color", "$value": "#000000" },
      "brand": {
        "500": { "$type": "color", "$value": "#3a72fb" }
      },
      "orange": {
        "500": { "$type": "color", "$value": "#ff8c40" }
      },
      "green": {
        "500": { "$type": "color", "$value": "#34c759" }
      },
      "red": {
        "500": { "$type": "color", "$value": "#ff3b30" }
      },
      "mint": {
        "500": { "$type": "color", "$value": "#63e6e2" }
      },
      "yellow": {
        "500": { "$type": "color", "$value": "#ffcc00" },
        "700": { "$type": "color", "$value": "#e6a600" }
      },
      "white-alpha": {
        "950": { "$type": "color", "$value": "rgba(255,255,255,0.95)" },
        "900": { "$type": "color", "$value": "rgba(255,255,255,0.90)" },
        "750": { "$type": "color", "$value": "rgba(255,255,255,0.75)" },
        "650": { "$type": "color", "$value": "rgba(255,255,255,0.65)" },
        "550": { "$type": "color", "$value": "rgba(255,255,255,0.55)" },
        "450": { "$type": "color", "$value": "rgba(255,255,255,0.45)" },
        "350": { "$type": "color", "$value": "rgba(255,255,255,0.35)" },
        "180": { "$type": "color", "$value": "rgba(255,255,255,0.18)" },
        "140": { "$type": "color", "$value": "rgba(255,255,255,0.14)" },
        "120": { "$type": "color", "$value": "rgba(255,255,255,0.12)" },
        "100": { "$type": "color", "$value": "rgba(255,255,255,0.10)" },
        "085": { "$type": "color", "$value": "rgba(255,255,255,0.85)" },
        "025": { "$type": "color", "$value": "rgba(255,255,255,0.25)" }
      },
      "black-alpha": {
        "280": { "$type": "color", "$value": "rgba(0,0,0,0.28)" },
        "120": { "$type": "color", "$value": "rgba(0,0,0,0.12)" }
      }
    },
    "semantic": {
      "immersive": {
        "text": {
          "primary": { "$value": "{color.base.white}" },
          "secondary": { "$value": "{color.base.white-alpha.550}" },
          "tertiary": { "$value": "{color.base.white-alpha.650}" },
          "emphasis": { "$value": "{color.base.white-alpha.950}" },
          "disabled": { "$value": "{color.base.white-alpha.450}" }
        },
        "surface": {
          "backdrop": { "$value": "{color.base.black}" },
          "glass-fill": { "$value": "{color.base.white-alpha.140}" },
          "glass-fill-subtle": { "$value": "{color.base.white-alpha.100}" },
          "glass-stroke": { "$value": "{color.base.white-alpha.120}" },
          "glass-stroke-strong": { "$value": "{color.base.white-alpha.180}" }
        },
        "status": {
          "warning": { "$value": "{color.base.orange.500}" }
        }
      },
      "standard": {
        "text": {
          "primary": { "$value": "UIColor.label" },
          "secondary": { "$value": "UIColor.secondaryLabel" }
        },
        "surface": {
          "primary": { "$value": "UIColor.systemBackground" }
        }
      }
    }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "7": { "$type": "dimension", "$value": "28px" },
    "page-x": { "$type": "dimension", "$value": "24px" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "12px" },
    "md": { "$type": "dimension", "$value": "14px" },
    "lg": { "$type": "dimension", "$value": "16px" },
    "xl": { "$type": "dimension", "$value": "18px" },
    "card": { "$type": "dimension", "$value": "28px" }
  },
  "sheet": {
    "amount-font-size": { "$type": "dimension", "$value": "56px" },
    "primary-button-height": { "$type": "dimension", "$value": "56px" },
    "keypad-key-height": { "$type": "dimension", "$value": "56px" }
  },
  "typography": {
    "size": {
      "xs": { "$type": "dimension", "$value": "12px" },
      "sm": { "$type": "dimension", "$value": "14px" },
      "md": { "$type": "dimension", "$value": "16px" },
      "lg": { "$type": "dimension", "$value": "18px" },
      "xl": { "$type": "dimension", "$value": "20px" },
      "xxl": { "$type": "dimension", "$value": "24px" },
      "xxxl": { "$type": "dimension", "$value": "40px" },
      "4xl": { "$type": "dimension", "$value": "56px" },
      "5xl": { "$type": "dimension", "$value": "80px" }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    },
    "tracking": {
      "tight-2": { "$type": "number", "$value": -2 },
      "tight-3": { "$type": "number", "$value": -3 },
      "tight-5": { "$type": "number", "$value": -5 }
    },
    "ramp": {
      "5xl-semibold": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.5xl}",
          "fontWeight": "{typography.weight.semibold}",
          "lineHeight": "{typography.size.5xl}",
          "letterSpacing": "{typography.tracking.tight-2}"
        }
      },
      "4xl-bold-mono": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.4xl}",
          "fontWeight": "{typography.weight.bold}",
          "lineHeight": "{typography.size.4xl}",
          "fontFamily": "monospaced"
        }
      },
      "3xl-semibold": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.xxxl}",
          "fontWeight": "{typography.weight.semibold}",
          "lineHeight": "{typography.size.xxxl}",
          "letterSpacing": "{typography.tracking.tight-2}"
        }
      },
      "2xl-medium": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.xxl}",
          "fontWeight": "{typography.weight.medium}",
          "lineHeight": "{typography.size.xxl}",
          "letterSpacing": "{typography.tracking.tight-2}"
        }
      },
      "lg-semibold": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.lg}",
          "fontWeight": "{typography.weight.semibold}",
          "lineHeight": "{typography.size.lg}",
          "letterSpacing": "{typography.tracking.tight-3}"
        }
      },
      "lg-semibold-mono": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.lg}",
          "fontWeight": "{typography.weight.semibold}",
          "lineHeight": "{typography.size.lg}",
          "letterSpacing": "{typography.tracking.tight-3}",
          "fontFamily": "monospaced"
        }
      },
      "lg-regular": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.lg}",
          "fontWeight": "{typography.weight.regular}",
          "lineHeight": "{typography.size.lg}",
          "letterSpacing": "{typography.tracking.tight-2}"
        }
      },
      "md-medium": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.md}",
          "fontWeight": "{typography.weight.medium}",
          "lineHeight": "{typography.size.md}",
          "letterSpacing": "{typography.tracking.tight-2}"
        }
      },
      "md-semibold-mono": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.md}",
          "fontWeight": "{typography.weight.semibold}",
          "lineHeight": "{typography.size.md}",
          "letterSpacing": "{typography.tracking.tight-5}",
          "fontFamily": "monospaced"
        }
      },
      "sm-semibold": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.sm}",
          "fontWeight": "{typography.weight.semibold}",
          "lineHeight": "{typography.size.sm}",
          "letterSpacing": "{typography.tracking.tight-5}"
        }
      },
      "sm-semibold-mono": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.sm}",
          "fontWeight": "{typography.weight.semibold}",
          "lineHeight": "{typography.size.sm}",
          "fontFamily": "monospaced"
        }
      },
      "sm-regular": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.sm}",
          "fontWeight": "{typography.weight.regular}",
          "lineHeight": "{typography.size.sm}",
          "letterSpacing": "{typography.tracking.tight-2}"
        }
      },
      "xs-regular": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.xs}",
          "fontWeight": "{typography.weight.regular}",
          "lineHeight": "{typography.size.xs}"
        }
      },
      "xl-regular-mono": {
        "$type": "typography",
        "$value": {
          "fontSize": "{typography.size.xl}",
          "fontWeight": "{typography.weight.regular}",
          "lineHeight": "{typography.size.xl}",
          "fontFamily": "monospaced"
        }
      }
    },
    "semantic": {
      "main-number": { "$value": "{typography.ramp.5xl-semibold}" },
      "list-card-number": { "$value": "{typography.ramp.3xl-semibold}" },
      "list-card-title": { "$value": "{typography.ramp.md-medium}" },
      "page-title": { "$value": "{typography.ramp.2xl-medium}" },
      "section-title": { "$value": "{typography.ramp.lg-semibold}" },
      "row-heavy": { "$value": "{typography.ramp.lg-semibold-mono}" },
      "row-light": { "$value": "{typography.ramp.lg-regular}" },
      "button": { "$value": "{typography.ramp.md-semibold-mono}" },
      "button-compact": { "$value": "{typography.ramp.sm-semibold}" },
      "meta": { "$value": "{typography.ramp.sm-regular}" },
      "sheet-title": { "$value": "{typography.ramp.2xl-medium}" },
      "sheet-subtitle": { "$value": "{typography.ramp.lg-regular}" },
      "sheet-amount": { "$value": "{typography.ramp.4xl-bold-mono}" },
      "sheet-keypad-digit": { "$value": "{typography.ramp.xl-regular-mono}" }
    }
  }
}
